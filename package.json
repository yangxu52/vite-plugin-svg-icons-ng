{
  "name": "vite-plugin-svg-icons-ng-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --filter './packages/*' run dev",
    "dev:playground": "pnpm run build && pnpm -r --filter './playground/*' run dev",
    "dev:docs": "pnpm --filter ./docs run dev",
    "build": "pnpm -r --filter './packages/*' run build",
    "build:playground": "pnpm run build && pnpm -r --filter './playground/*' run build",
    "build:docs": "pnpm --filter ./docs run build",
    "test": "pnpm -r --filter './packages/*' run test",
    "coverage": "pnpm -r --filter './packages/*' run coverage",
    "clean": "pnpm -r --if-present run clean",
    "format": "prettier --write .",
    "lint": "eslint --fix .",
    "tsc": "tsc --noEmit --skipLibCheck",
    "prepare": "husky"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "svg",
    "sprite",
    "svgo"
  ],
  "homepage": "https://blog.yangxu52.top/vite-plugin-svg-icons-ng",
  "bugs": {
    "url": "https://github.com/yangxu52/vite-plugin-svg-icons-ng/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yangxu52/vite-plugin-svg-icons-ng.git"
  },
  "license": "MIT",
  "author": "yangxu52",
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "4.1.0",
    "commit-and-tag-version": "^12.7.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.4.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": "^18.0.0 || ^20.0.0 || >=22.0.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!(*.js|*.mjs|*.cjs|*.ts|*.mts|*.cts)": [
      "prettier --write --ignore-unknown"
    ]
  }
}
