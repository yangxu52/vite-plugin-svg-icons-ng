{
  "name": "vite-plugin-svg-icons-ng-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --filter './packages/*' run dev",
    "dev:playground": "pnpm run build && pnpm -r --filter './playground/*' run dev",
    "dev:docs": "pnpm --filter ./docs run dev",
    "build": "pnpm -r --filter './packages/*' run build",
    "build:playground": "pnpm run build && pnpm -r --filter './playground/*' run build",
    "build:docs": "pnpm --filter ./docs run build",
    "test": "pnpm -r --filter './packages/*' run test",
    "test:browser": "pnpm --filter vite-plugin-svg-icons-ng run test:browser",
    "test:all": "pnpm run test && pnpm run test:browser",
    "coverage": "pnpm -r --filter './packages/*' run coverage",
    "clean": "pnpm -r --if-present run clean",
    "format": "prettier --write .",
    "lint": "eslint --fix .",
    "typecheck": "tsc -b",
    "typecheck:playground": "pnpm -r --filter './playground/*' run typecheck",
    "prepare": "husky"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "svg",
    "sprite",
    "svgo"
  ],
  "homepage": "https://blog.yangxu52.top/vite-plugin-svg-icons-ng",
  "bugs": {
    "url": "https://github.com/yangxu52/vite-plugin-svg-icons-ng/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yangxu52/vite-plugin-svg-icons-ng.git"
  },
  "license": "MIT",
  "author": "yangxu52",
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "catalog:",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "typescript": "catalog:",
    "typescript-eslint": "^8.63.0"
  },
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!(*.js|*.mjs|*.cjs|*.ts|*.mts|*.cts)": [
      "prettier --write --ignore-unknown"
    ]
  }
}
