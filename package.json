{
  "name": "vite-plugin-svg-icons-ng-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "author": "yangxu52",
  "scripts": {
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm --filter vite-plugin-svg-icons-ng run dev",
    "dev": "pnpm run build && pnpm -r --filter ./playground/* run dev",
    "build": "pnpm --filter vite-plugin-svg-icons-ng run build",
    "build:docs": "pnpm --filter ./docs run docs:build",
    "build:playground": "pnpm -r --filter ./playground/* run build",
    "test": "pnpm build &&pnpm test-unit && pnpm test-build",
    "test-unit": "vitest run",
    "test-build": "pnpm --filter playground-test-gallery run build",
    "lint": "eslint --fix .",
    "format": "prettier --write .",
    "tsc": "tsc --noEmit --skipLibCheck",
    "log": "pnpm --filter vite-plugin-svg-icons-ng run log",
    "release": "node scripts/release.mjs"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "svg",
    "sprite",
    "svgo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yangxu52/vite-plugin-svg-icons-ng.git"
  },
  "bugs": {
    "url": "https://github.com/yangxu52/vite-plugin-svg-icons-ng/issues"
  },
  "homepage": "https://blog.yangxu52.top/vite-plugin-svg-icons-ng",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "conventional-changelog": "^7.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.4.2"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!(*.js|*.mjs|*.cjs|*.ts|*.mts|*.cts)": [
      "prettier --write --ignore-unknown"
    ]
  }
}
