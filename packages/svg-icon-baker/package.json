{
  "name": "svg-icon-baker",
  "version": "2.0.1",
  "description": "A delightful toolkit for baking raw SVG icons into delicious SVG symbol sprites",
  "keywords": [
    "svg",
    "icon",
    "symbol",
    "sprite",
    "optimize",
    "transform",
    "convert"
  ],
  "homepage": "https://github.com/yangxu52/svg-icon-baker",
  "bugs": {
    "url": "https://github.com/yangxu52/svg-icon-baker/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yangxu52/vite-plugin-svg-icons-ng.git",
    "directory": "packages/svg-icon-baker"
  },
  "license": "MIT",
  "author": "yangxu52",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "unbuild --stub",
    "build": "unbuild",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "clean": "rimraf dist",
    "release": "commit-and-tag-version --path . -t svg-icon-baker@"
  },
  "dependencies": {
    "css-tree": "^3.2.1",
    "fast-xml-builder": "^1.1.9",
    "fast-xml-parser": "^5.7.3",
    "svgo": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "unbuild": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^18.0.0 || ^20.0.0 || >=22.0.0"
  }
}
