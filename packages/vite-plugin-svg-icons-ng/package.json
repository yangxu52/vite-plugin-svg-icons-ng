{
  "name": "vite-plugin-svg-icons-ng",
  "version": "1.8.0",
  "description": "Vite plugin for easily creating an SVG sprite and injecting it for use, with a brand-new version.",
  "type": "module",
  "license": "MIT",
  "author": "yangxu52",
  "files": [
    "dist",
    "client.d.ts"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./client.d.ts"
    }
  },
  "engines": {
    "node": "^18.0.0 || ^20.0.0 || >=22.0.0"
  },
  "scripts": {
    "dev": "unbuild --stub",
    "build": "unbuild",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build",
    "log": "conventional-changelog -p angular --commit-path . -t v"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "svg",
    "icon",
    "svg-icon",
    "svg-icons",
    "sprite",
    "spritemap",
    "spritesheet",
    "svg-sprite",
    "svg-sprites",
    "symbol",
    "svg-symbol",
    "svgo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yangxu52/vite-plugin-svg-icons-ng.git",
    "directory": "packages/vite-plugin-svg-icons-ng"
  },
  "bugs": {
    "url": "https://github.com/yangxu52/vite-plugin-svg-icons-ng/issues"
  },
  "homepage": "https://blog.yangxu52.top/vite-plugin-svg-icons-ng",
  "dependencies": {
    "svg-icon-baker": "^1.2.0",
    "tinyglobby": "^0.2.16"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "unbuild": "^3.6.1"
  }
}
