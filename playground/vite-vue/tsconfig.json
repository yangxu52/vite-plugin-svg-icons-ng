{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    // allow js files
    "allowJs": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    // add DOM and DOM.Iterable to prevent empty import errors
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    // add types for vite/client and vite-plugin-svg-icons-ng
    "types": ["vite/client", "vite-plugin-svg-icons-ng/client"]
  },
  "references": [{ "path": "../../packages/vite-plugin-svg-icons-ng" }],
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"],
  "exclude": ["dist"]
}
